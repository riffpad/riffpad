# Go Backend
PORT=8080
API_URL=http://localhost:8080

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/riffpad?sslmode=disable

# Upstash Redis (or local Redis for dev)
REDIS_URL=redis://localhost:6379/0

# Supabase Storage / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=riffpad-snapshots
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# LLM Provider (OpenAI-compatible endpoint)
# LLM_PROVIDER is optional/informational; only LLM_BASE_URL, LLM_API_KEY, and LLM_MODEL are required.
# Examples:
#   火山引擎 Ark: https://ark.cn-beijing.volces.com/api/v3
#   阿里云百炼:    https://dashscope.aliyuncs.com/compatible-mode/v1
#   硅基流动:      https://api.siliconflow.cn/v1
#   DeepSeek:     https://api.deepseek.com/v1
#   OpenAI:       https://api.openai.com/v1
# LLM_PROVIDER=volcengine
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=sk-xxx
LLM_MODEL=doubao-pro-32k-xxx

# Reasoning controls for providers like SiliconFlow that expose thinking parameters.
# Set LLM_ENABLE_THINKING=false to disable long reasoning phases and keep agent loops fast.
# LLM_ENABLE_THINKING=false
# LLM_THINKING_BUDGET=1024

# Context management: auto-compact conversation history when it grows too large.
# Compaction is triggered when estimated tokens exceed CONTEXT_WINDOW - RESERVE_TOKENS.
# LLM_CONTEXT_WINDOW=128000
# LLM_RESERVE_TOKENS=16384
# LLM_KEEP_RECENT_TOKENS=20480

# Sandbox
SANDBOX_RUNTIME=docker
SANDBOX_WORKER_URL=http://localhost:9090
SANDBOX_IMAGE=riffpad-node-python

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
